---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SuggestionForm from "../components/SuggestionForm.astro";
import { techniques, categoryMeta } from "../data/techniques";
import TechniqueCard from "../components/TechniqueCard.astro";

const categories = Object.entries(categoryMeta);
---

<Layout title="VibeBalm — Free Anxiety Relief Techniques">
  <Header />

  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-sage-100 via-lavender-50 to-warm-50"></div>
    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 py-20 sm:py-28 text-center">
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-sage-900 leading-tight mb-6">
        Your anxiety toolkit.
      </h1>
      <p class="text-lg sm:text-xl text-sage-600 max-w-2xl mx-auto mb-8 leading-relaxed">
        Learn evidence-based techniques to manage anxiety — completely free.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="#techniques"
          class="bg-sage-800 hover:bg-sage-700 text-white font-semibold px-8 py-3.5 rounded-full transition-all duration-200 hover:shadow-lg hover:-translate-y-0.5"
        >
          Explore Techniques
        </a>
      </div>
    </div>
  </section>

  <!-- Techniques Section -->
  <section id="techniques" class="max-w-7xl mx-auto px-4 sm:px-6 py-16">
    <!-- Category Tabs -->
    <div class="mb-12 overflow-x-auto">
      <div class="flex gap-3 min-w-max pb-2 justify-center" id="category-tabs">
        {categories.map(([key, cat]) => (
          <button
            data-category={key}
            class={`category-tab flex-shrink-0 px-5 py-2.5 rounded-full text-sm font-semibold border-2 transition-all duration-200 ${
              key === "all"
                ? "bg-sage-800 border-sage-800 text-white shadow-md"
                : "bg-white border-sage-200 text-sage-600 hover:border-sage-400 hover:text-sage-900 hover:shadow-sm"
            }`}
          >
            {cat.label}
          </button>
        ))}
      </div>
    </div>

    <!-- Technique Cards Grid -->
    <div id="technique-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 grid-rows-[auto]">
      {techniques.map((technique) => (
        <div
          data-card-category={technique.category}
          class="technique-card"
        >
          <TechniqueCard
            slug={technique.slug}
            emoji={technique.emoji}
            title={technique.title}
            subtitle={technique.subtitle}
          />
        </div>
      ))}
    </div>

    <!-- Empty state -->
    <div id="empty-state" class="hidden text-center py-16">
      <span class="text-5xl block mb-4">🤔</span>
      <p class="text-sage-500 text-lg">No techniques in this category yet.</p>
    </div>
  </section>

  <!-- How It Works -->
  <section id="how-it-works" class="bg-white border-y border-sage-200">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-16">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-bold text-sage-900 mb-4">How It Works</h2>
        <p class="text-sage-600">Three simple steps to a calmer day.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-sage-100 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-4">📖</div>
          <h3 class="font-bold text-sage-900 text-lg mb-2">1. Learn</h3>
          <p class="text-sage-600 text-sm leading-relaxed">Read about each technique — what it is, when to use it, and step-by-step instructions. All content is free.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-lavender-100 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-4">🧘</div>
          <h3 class="font-bold text-sage-900 text-lg mb-2">2. Practice</h3>
          <p class="text-sage-600 text-sm leading-relaxed">Try the techniques in your daily life. Most take less than 5 minutes and work anywhere.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-warm-100 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-4">✨</div>
          <h3 class="font-bold text-sage-900 text-lg mb-2">3. Transform</h3>
          <p class="text-sage-600 text-sm leading-relaxed">Build lasting habits and resilience. These techniques work with consistent practice.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-16 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-sage-900 mb-4">Ready to start?</h2>
    <p class="text-sage-600 max-w-lg mx-auto mb-8">Evidence-based techniques for anxiety relief. Completely free.</p>
    <a
      href="#techniques"
      class="inline-flex items-center gap-2 bg-sage-800 hover:bg-sage-700 text-white font-semibold px-8 py-3.5 rounded-full transition-all duration-200 hover:shadow-lg hover:-translate-y-0.5"
    >
      Explore Techniques
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </a>
  </section>

  <!-- Suggestion CTA Section -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-16 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-sage-900 mb-4">Have feedback?</h2>
    <p class="text-sage-600 max-w-lg mx-auto mb-8">
      Help us improve VibeBalm. Share your thoughts, report bugs, or suggest features.
    </p>
    <button
      onclick="openSuggestionModal()"
      class="inline-flex items-center gap-2 bg-sage-800 hover:bg-sage-700 text-white font-semibold px-8 py-3.5 rounded-full transition-all duration-200 hover:shadow-lg hover:-translate-y-0.5"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
      </svg>
      Send Suggestion
    </button>
  </section>

  <Footer />
  
  <!-- Suggestion Form Modal -->
  <SuggestionForm />
</Layout>

<script>
  document.querySelectorAll('.category-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const category = tab.getAttribute('data-category');
      document.querySelectorAll('.category-tab').forEach(t => {
        t.classList.remove('bg-sage-800', 'border-sage-800', 'text-white', 'shadow-md');
        t.classList.add('bg-white', 'border-sage-200', 'text-sage-600');
      });
      tab.classList.remove('bg-white', 'border-sage-200', 'text-sage-600');
      tab.classList.add('bg-sage-800', 'border-sage-800', 'text-white', 'shadow-md');
      const cards = document.querySelectorAll('.technique-card');
      let visibleCount = 0;
      cards.forEach(card => {
        if (category === 'all' || card.getAttribute('data-card-category') === category) {
          card.style.display = '';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      });
      const emptyState = document.getElementById('empty-state');
      if (emptyState) emptyState.classList.toggle('hidden', visibleCount > 0);
    });
  });
</script>
