---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { techniques } from "../data/techniques";
---

<Layout title="Wallpapers — VibeBalm">
  <Header />

  <section class="max-w-7xl mx-auto px-4 sm:px-6 py-12 sm:py-20">
    <!-- Header -->
    <div class="text-center mb-12">
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-sage-900 mb-4">Wallpapers</h1>
      <p class="text-sage-600 text-lg max-w-2xl mx-auto leading-relaxed">
        Beautiful reminders for your phone and desktop. Each wallpaper is paired with a mental health technique.
      </p>
    </div>

    <!-- Device Tabs -->
    <div class="flex justify-center gap-3 mb-10">
      <button
        id="tab-phone"
        class="device-tab px-6 py-2.5 rounded-full text-sm font-semibold border-2 transition-all duration-200 bg-sage-800 border-sage-800 text-white shadow-md"
        data-device="phone"
      >
        📱 Phone Wallpapers
      </button>
      <button
        id="tab-desktop"
        class="device-tab px-6 py-2.5 rounded-full text-sm font-semibold border-2 transition-all duration-200 bg-white border-sage-200 text-sage-600 hover:border-sage-400 hover:text-sage-900"
        data-device="desktop"
      >
        🖥️ Desktop Wallpapers
      </button>
    </div>

    <!-- Phone Wallpapers -->
    <div id="wallpapers-phone" class="wallpaper-grid">
      <div class="text-sm text-sage-500 text-center mb-6">18 wallpapers · 1080 × 1920px (iPhone) · 1440 × 3200px (Android)</div>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6">
        {techniques.map((t) => (
          <div class="wallpaper-item group" data-slug={t.slug} data-title={t.title} data-quote={t.wallpaperQuote}>
            <div class="relative aspect-[9/16] rounded-2xl overflow-hidden bg-gradient-to-br from-sage-200 via-lavender-100 to-warm-100 shadow-sm group-hover:shadow-xl transition-all duration-300">
              <!-- Placeholder image -->
              <div class="absolute inset-0 flex flex-col items-center justify-center p-4">
                <span class="text-4xl mb-3">{t.emoji}</span>
                <p class="text-sage-600 text-xs font-medium text-center leading-relaxed line-clamp-3">"{t.wallpaperQuote}"</p>
                <p class="text-sage-400 text-[10px] mt-auto">Coming Soon</p>
              </div>
              <!-- Hover overlay -->
              <div class="wallpaper-overlay absolute inset-0 bg-black/60 backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-all duration-300 flex flex-col items-center justify-center gap-3 p-4 rounded-2xl">
                <p class="text-white text-sm font-semibold text-center leading-relaxed">"{t.wallpaperQuote}"</p>
                <div class="flex flex-col gap-2 w-full">
                  <a
                    href={`/${t.slug}`}
                    class="flex items-center justify-center gap-2 bg-white/90 hover:bg-white text-sage-900 font-semibold py-2.5 px-4 rounded-full text-sm transition-colors"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                    Learn Method
                  </a>
                  <a
                    href={`/buy/${t.slug}`}
                    class="flex items-center justify-center gap-2 bg-amber-500 hover:bg-amber-600 text-white font-semibold py-2.5 px-4 rounded-full text-sm transition-colors"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
                    Download — $0.99
                  </a>
                </div>
              </div>
            </div>
            <p class="mt-3 text-center text-xs font-medium text-sage-600 truncate">{t.title}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Desktop Wallpapers -->
    <div id="wallpapers-desktop" class="wallpaper-grid hidden">
      <div class="text-sm text-sage-500 text-center mb-6">18 wallpapers · 2560 × 1440px (16:9) · 3840 × 2160px (4K)</div>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
        {techniques.map((t) => (
          <div class="wallpaper-item group" data-slug={t.slug} data-title={t.title} data-quote={t.wallpaperQuote}>
            <div class="relative aspect-[16/10] rounded-2xl overflow-hidden bg-gradient-to-br from-sage-200 via-lavender-100 to-warm-100 shadow-sm group-hover:shadow-xl transition-all duration-300">
              <div class="absolute inset-0 flex flex-col items-center justify-center p-6">
                <span class="text-5xl mb-4">{t.emoji}</span>
                <p class="text-sage-600 text-sm font-medium text-center leading-relaxed">"{t.wallpaperQuote}"</p>
                <p class="text-sage-400 text-xs mt-4">Desktop Wallpaper · Coming Soon</p>
              </div>
              <div class="wallpaper-overlay absolute inset-0 bg-black/60 backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-all duration-300 flex flex-col items-center justify-center gap-4 p-6 rounded-2xl">
                <p class="text-white text-base font-semibold text-center leading-relaxed">"{t.wallpaperQuote}"</p>
                <p class="text-white/70 text-sm">{t.title}</p>
                <div class="flex flex-col sm:flex-row gap-3 w-full">
                  <a
                    href={`/${t.slug}`}
                    class="flex items-center justify-center gap-2 bg-white/90 hover:bg-white text-sage-900 font-semibold py-2.5 px-6 rounded-full text-sm transition-colors"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                    Learn Method
                  </a>
                  <a
                    href={`/buy/${t.slug}`}
                    class="flex items-center justify-center gap-2 bg-amber-500 hover:bg-amber-600 text-white font-semibold py-2.5 px-6 rounded-full text-sm transition-colors"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
                    Download
                  </a>
                </div>
              </div>
            </div>
            <p class="mt-3 text-center text-sm font-medium text-sage-600 truncate">{t.title}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="mt-16 text-center">
      <p class="text-sage-500 text-sm mb-4">Full collection: 18 phone wallpapers + 18 desktop wallpapers</p>
      <a
        href="/buy/five-second-rule"
        class="inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-600 text-white font-semibold px-8 py-3.5 rounded-full transition-all duration-200 hover:shadow-lg hover:-translate-y-0.5"
      >
        Buy Full Collection — $4.99
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7-7" /></svg>
      </a>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  const tabs = document.querySelectorAll('.device-tab');
  const phoneGrid = document.getElementById('wallpapers-phone');
  const desktopGrid = document.getElementById('wallpapers-desktop');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const device = tab.getAttribute('data-device');

      tabs.forEach(t => {
        t.classList.remove('bg-sage-800', 'border-sage-800', 'text-white', 'shadow-md');
        t.classList.add('bg-white', 'border-sage-200', 'text-sage-600');
      });
      tab.classList.remove('bg-white', 'border-sage-200', 'text-sage-600');
      tab.classList.add('bg-sage-800', 'border-sage-800', 'text-white', 'shadow-md');

      if (device === 'phone') {
        phoneGrid?.classList.remove('hidden');
        desktopGrid?.classList.add('hidden');
      } else {
        phoneGrid?.classList.add('hidden');
        desktopGrid?.classList.remove('hidden');
      }
    });
  });
</script>
