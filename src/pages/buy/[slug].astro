---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { techniques } from "../../data/techniques";

export function getStaticPaths() {
  return techniques.map((t) => ({
    params: { slug: t.slug },
    props: { technique: t },
  }));
}

const { technique } = Astro.props;

const pageTitle = `Buy "${technique.wallpaperQuote}" Wallpaper — VibeBalm`;
---

<Layout title={pageTitle} description={`Purchase the ${technique.title} phone wallpaper from VibeBalm.`}>
  <Header />

  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <!-- Back link -->
    <a href={`/${technique.slug}`} class="inline-flex items-center gap-1 text-sage-500 hover:text-sage-700 text-sm mb-8 transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Back to technique
    </a>

    <!-- Product Hero -->
    <div class="text-center mb-12">
      <span class="text-5xl block mb-4">{technique.emoji}</span>
      <h1 class="text-3xl sm:text-4xl font-bold text-sage-900 mb-3">Phone Wallpaper</h1>
      <p class="text-sage-600 text-lg italic font-serif mb-2">"{technique.wallpaperQuote}"</p>
      <p class="text-sage-500 text-sm">From <a href={`/${technique.slug}`} class="text-sage-700 hover:text-sage-900 underline underline-offset-2">{technique.title}</a></p>
    </div>

    <!-- Wallpaper Preview -->
    <div class="mb-12">
      <div class="rounded-2xl overflow-hidden aspect-[9/16] max-w-[300px] mx-auto bg-gradient-to-br from-sage-200 via-lavender-100 to-warm-200 flex items-center justify-center p-8">
        <div class="text-center">
          <p class="text-sage-700 font-serif text-2xl leading-relaxed italic">"{technique.wallpaperQuote}"</p>
          <p class="text-sage-400 text-sm mt-6">VibeBalm</p>
          <div class="mt-8 pt-4 border-t border-sage-300/50">
            <p class="text-sage-400 text-xs">Preview — Full HD after purchase</p>
          </div>
        </div>
      </div>
    </div>

    <!-- What you get -->
    <div class="bg-sage-50 rounded-2xl p-8 mb-8 border border-sage-200">
      <h2 class="text-xl font-bold text-sage-900 mb-4">What You Get</h2>
      <ul class="space-y-3 text-sage-700">
        <li class="flex items-start gap-3">
          <svg class="w-5 h-5 text-sage-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
          <span>HD phone wallpaper (1080 × 1920px, PNG)</span>
        </li>
        <li class="flex items-start gap-3">
          <svg class="w-5 h-5 text-sage-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
          <span>Hi-Res version (1440 × 3200px, PNG) for Android</span>
        </li>
        <li class="flex items-start gap-3">
          <svg class="w-5 h-5 text-sage-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
          <span>Minimalist design, no watermark</span>
        </li>
        <li class="flex items-start gap-3">
          <svg class="w-5 h-5 text-sage-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
          <span>Instant download after payment</span>
        </li>
      </ul>
    </div>

    <!-- Pricing Options -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-12">
      <!-- Single Wallpaper -->
      <div class="bg-white rounded-2xl p-8 border-2 border-sage-200 hover:border-sage-400 transition-colors">
        <h3 class="font-bold text-sage-900 text-lg mb-1">Single Wallpaper</h3>
        <p class="text-sage-500 text-sm mb-6">"{technique.wallpaperQuote}"</p>
        <div class="mb-6">
          <span class="text-4xl font-bold text-sage-900">$0.99</span>
          <span class="text-sage-500 text-sm ml-1">USD</span>
        </div>
        <form action="https://www.paypal.com/cgi-bin/webscr" method="post" target="_top">
          <input type="hidden" name="cmd" value="_xclick" />
          <input type="hidden" name="business" value="YOUR_PAYPAL_EMAIL@example.com" />
          <input type="hidden" name="item_name" value={`VibeBalm: ${technique.wallpaperQuote} Wallpaper`} />
          <input type="hidden" name="item_number" value={technique.slug} />
          <input type="hidden" name="amount" value="0.99" />
          <input type="hidden" name="currency_code" value="USD" />
          <input type="hidden" name="no_shipping" value="1" />
          <input type="hidden" name="return" value={`https://vibebalm.co/${technique.slug}/thank-you`} />
          <input type="hidden" name="cancel_return" value={`https://vibebalm.co/${technique.slug}/buy`} />
          <button type="submit" class="w-full bg-sage-800 hover:bg-sage-700 text-white font-semibold py-3.5 rounded-full transition-all duration-200 hover:shadow-lg">
            Buy with PayPal
          </button>
        </form>
      </div>

      <!-- Full Collection -->
      <div class="bg-white rounded-2xl p-8 border-2 border-amber-300 relative">
        <span class="absolute -top-3 left-6 bg-amber-400 text-amber-900 text-xs font-bold px-3 py-1 rounded-full">
          BEST VALUE
        </span>
        <h3 class="font-bold text-sage-900 text-lg mb-1">Full Collection</h3>
        <p class="text-sage-500 text-sm mb-6">All {techniques.length} wallpapers + future updates</p>
        <div class="mb-6">
          <span class="text-4xl font-bold text-sage-900">$4.99</span>
          <span class="text-sage-500 text-sm ml-1">USD</span>
          <span class="text-amber-600 text-sm ml-2 font-medium">Save 72%</span>
        </div>
        <form action="https://www.paypal.com/cgi-bin/webscr" method="post" target="_top">
          <input type="hidden" name="cmd" value="_xclick" />
          <input type="hidden" name="business" value="YOUR_PAYPAL_EMAIL@example.com" />
          <input type="hidden" name="item_name" value="VibeBalm: Full Wallpaper Collection (18 wallpapers)" />
          <input type="hidden" name="amount" value="4.99" />
          <input type="hidden" name="currency_code" value="USD" />
          <input type="hidden" name="no_shipping" value="1" />
          <input type="hidden" name="return" value="https://vibebalm.co/thank-you" />
          <input type="hidden" name="cancel_return" value="https://vibebalm.co/buy/full" />
          <button type="submit" class="w-full bg-amber-500 hover:bg-amber-600 text-white font-semibold py-3.5 rounded-full transition-all duration-200 hover:shadow-lg">
            Buy with PayPal
          </button>
        </form>
      </div>
    </div>

    <!-- FAQ -->
    <div class="mb-12">
      <h2 class="text-xl font-bold text-sage-900 mb-4">FAQ</h2>
      <div class="space-y-4 text-sm">
        <details class="bg-white rounded-xl border border-sage-200 p-4">
          <summary class="font-semibold text-sage-900 cursor-pointer">What format are the wallpapers?</summary>
          <p class="text-sage-600 mt-2">PNG format, available in two sizes: 1080×1920px (iPhone) and 1440×3200px (Android hi-res). No watermarks on the purchased version.</p>
        </details>
        <details class="bg-white rounded-xl border border-sage-200 p-4">
          <summary class="font-semibold text-sage-900 cursor-pointer">How do I download after payment?</summary>
          <p class="text-sage-600 mt-2">After completing payment via PayPal, you'll be redirected to a download page. The files are also sent to your PayPal email address.</p>
        </details>
        <details class="bg-white rounded-xl border border-sage-200 p-4">
          <summary class="font-semibold text-sage-900 cursor-pointer">Can I use these commercially?</summary>
          <p class="text-sage-600 mt-2">These wallpapers are for personal use. For commercial licensing, please contact us at hello@vibebalm.co.</p>
        </details>
        <details class="bg-white rounded-xl border border-sage-200 p-4">
          <summary class="font-semibold text-sage-900 cursor-pointer">What if I'm not satisfied?</summary>
          <p class="text-sage-600 mt-2">We offer a 30-day money-back guarantee. If you're not happy, email us and we'll refund you — no questions asked.</p>
        </details>
      </div>
    </div>

    <!-- Trust -->
    <div class="text-center text-sage-400 text-xs space-y-1">
      <p>Payments processed securely by PayPal. We never see your card details.</p>
      <p>30-day money-back guarantee.</p>
    </div>
  </div>

  <Footer />
</Layout>
