---
interface Props {
  quote: string;
  gumroadLink?: string;
}

const { quote, gumroadLink = "#" } = Astro.props;
---

<div class="relative group">
  <!-- Wallpaper Preview (blurred placeholder) -->
  <div class="wallpaper-preview rounded-2xl overflow-hidden aspect-[9/16] max-w-[280px] mx-auto bg-gradient-to-br from-sage-300 via-lavender-200 to-warm-200">
    <div class="absolute inset-0 flex items-center justify-center">
      <div class="text-center p-8">
        <p class="text-sage-700 font-serif text-xl sm:text-2xl leading-relaxed italic">
          "{quote}"
        </p>
        <p class="text-sage-500 text-sm mt-4">CalmWall</p>
      </div>
    </div>
  </div>

  <!-- CTA Overlay -->
  <div class="mt-6 text-center">
    <a
      href={gumroadLink}
      target="_blank"
      rel="noopener"
      class="inline-flex items-center gap-2 bg-sage-800 hover:bg-sage-700 text-white font-semibold px-6 py-3 rounded-full transition-all duration-200 hover:shadow-lg hover:-translate-y-0.5"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
      </svg>
      Get This Wallpaper — $0.99
    </a>
    <p class="text-sage-500 text-xs mt-2">Full collection (15 wallpapers) — $4.99</p>
  </div>
</div>
