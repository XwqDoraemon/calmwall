---
interface Props {
  slug: string;
  emoji: string;
  title: string;
  subtitle: string;
}

const { slug, emoji, title, subtitle } = Astro.props;
---

<a
  href={`/${slug}`}
  class="group flex flex-col rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1 bg-white border border-sage-200 h-full"
>
  <div class="p-6 sm:p-8 flex-1 flex flex-col">
    <span class="text-4xl mb-4 block">{emoji}</span>
    <h3 class="text-xl sm:text-2xl font-bold text-sage-900 mb-2 group-hover:underline underline-offset-4">
      {title}
    </h3>
    <p class="text-sage-600 text-sm sm:text-base leading-relaxed flex-1">
      {subtitle}
    </p>
  </div>
  <div class="px-6 pb-6">
    <span class="inline-flex items-center gap-1 text-sm font-medium text-sage-500 bg-sage-50 rounded-full px-4 py-1.5 group-hover:bg-sage-100 group-hover:text-sage-700 transition-colors">
      Learn the technique
      <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7-7" />
      </svg>
    </span>
  </div>
</a>
